<!DOCTYPE html>
<html>
<head>
<meta http-equiv="content-type" content="text/html; charset=utf-8">

    
    <title>Two-sample designs</title>
    <link href="style.css" rel="stylesheet" type="text/css">
    <script type="text/javascript" src="main.js"></script>
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/jstat@latest/dist/jstat.min.js"></script>
    <script src="https://cdn.plot.ly/plotly-latest.min.js"></script>
    <script type="text/javascript" src="two_sample.js"></script>
  </head>
  <body onload="drawCharts()">
    
<div id="wrapper_div1" style="float: left; border: solid black 4px; margin-right: 20px; width: 350px;">
        <div id="chart_div1" style="width: 350; height: 350px;"></div>
        <p id="difference"></p>
        <button type="button" id="just_randomize" onclick="drawChart1()">Randomize</button>
      </div>
      
<div id="wrapper_div3" style="float: left; border: solid black 4px; margin-right: 10px; width: 600px; padding: 10px;">
        <div id="chart_div3" style="width: 600; height: 300px;"></div>
        <p>t<sub>obs</sub> = <span id="t_obs_se_diff" style="color: red">4.29</span>,
          p = <span id="p_obs_se_diff">0.00043</span><button id="reset_t_dists" onclick="resetToObs()" style="float: right">Reset</button></p>
        <div id="diff_div" style="float: left; border: solid black 2px; padding: 5px">
          <p>Difference between the means</p>
          <p><span style="text-decoration: overline">x</span><sub>Control</sub>&nbsp;-&nbsp;<span style="text-decoration: overline">x</span><sub>GABA</sub> = <input id="diff_means" min="0" value="5.2" step="0.1" onchange="drawChart3()" style="width: 50px" type="number"></p>
        </div>
        <div id="se_div" style="float: right; border: solid black 2px; padding: 5px">
          <p>Standard error, determined by:</p>
          <p>Standard deviation = <input id="std_dev" min="0.1" value="2.7" step="0.1" onchange="drawChart3()" style="width: 50px" type="number"> </p>
          <p>n per group = <input id="n_t_comp" min="2" value="10" onchange="drawChart3()" style="width: 50px" type="number"></p>
        </div>
      </div>
      <div id="wrapper_div2" style="float: left; border: solid black 4px; margin-right: 10px; width: 500px;">
        <div id="chart_div2" style="width: 500; height: 300px;"></div>
        <p>Numerator df: <input id="num_df" min="1" value="1" onchange="drawChart2()" style="width: 50px" type="number">Denominator df: <input id="denom_df" min="1" value="18" onchange="drawChart2()" style="width: 50px" type="number"></p>
        <p>Critical F = <span id="fcrit">4.414</span></p>
      </div>
</body></html>