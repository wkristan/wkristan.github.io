    <title>Relationship between the t distribution and a t-table</title>
    <link href="https://wkristan.github.io/style.css" rel="stylesheet" type="text/css">
    <style type="text/css">

table {
  overflow: hidden;
  border-collapse: collapse;
  width: 100%;
  margin-bottom: 20px;
}

tr:hover {
  background-color: #ffa;
}

td, th {
  position: relative;
  border: 1px solid black;
  width: 60px;
  text-align: center;
}
      
td:hover::after,
th:hover::after {
  content: "";
  position: absolute;
  background-color: #e6ffff;
  left: 0;
  top: -5000px;
  height: 10000px;
  width: 100%;
  z-index: -1;
}
      
td.myClass:hover {
  background-color: #00ff00;
  color: black;
}

</style> 
    <script type="text/javascript" src="https://wkristan.github.io/main.js"></script>
